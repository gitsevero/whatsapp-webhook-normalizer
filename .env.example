# HTTP server
PORT=3000

# Supabase Postgres — connection string
# Como obter:
#   1. Crie uma conta grátis em https://supabase.com/dashboard
#   2. New project → aguarde o provisionamento
#   3. Project Settings → Database → Connection string → "URI"
#   4. Substitua [YOUR-PASSWORD] pela senha definida na criação do projeto
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Meta Cloud API (seção de segurança — Chunk 6)
# App Secret: usado para validar HMAC-SHA256 do header X-Hub-Signature-256
META_APP_SECRET=
# Verify token: string arbitrária definida por você; a Meta devolve no handshake inicial (GET /webhooks/meta)
META_VERIFY_TOKEN=

# LLM para classificação de intenção (Chunk 9 — diferencial)
# Deixe em branco para rodar sem classificação (ingestão continua funcionando normalmente)
OPENAI_API_KEY=
